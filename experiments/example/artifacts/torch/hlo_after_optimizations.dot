digraph G {
  rankdir=TB;
  concentrate=true;
  label="After Optimisations  [torch]\nModule: SyncTensorsGraph.8\n4 instructions";
  labelloc=t; fontsize=16;
  node [style=filled, fontsize=9, fontname="Helvetica"];
  edge [arrowsize=0.4, color="#666666"];
  n_p1_3 [label="parameter\nf32[256,1024]", fillcolor="#B3D9FF", shape=box];
  n_p0_2 [label="parameter\nf32[256,1024]", fillcolor="#B3D9FF", shape=box];
  n_add_6 [label="add\nf32[256,1024]", fillcolor="#C5E1A5", shape=ellipse];
  n_tuple_7 [label="tuple\n(f32[256,1024])", fillcolor="#F5F5F5", shape=box, penwidth=3];
  n_p1_3 -> n_add_6;
  n_p0_2 -> n_add_6;
  n_add_6 -> n_tuple_7;
  subgraph cluster_legend {
    label="Op Counts"; style=dashed; fontsize=11;
    legend [label="parameter: 2\ladd: 1\ltuple: 1\l", shape=note, fillcolor="#FFFDE7", fontsize=8];
  }
}